{
  "name": "crosspost",
  "version": "0.1.0",
  "description": "Cross-platform content publishing from the terminal. Bring your own keys. No server. No subscription. Post everywhere.",
  "type": "module",
  "main": "src/cli.tsx",
  "bin": {
    "crosspost": "src/cli.tsx"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "build": "bun build src/cli.tsx --compile --outfile dist/crosspost",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "web:server": "bun web/server/index.ts",
    "web:client": "bunx vite --config web/vite.config.ts",
    "web:dev": "concurrently \"bun run web:server\" \"bun run web:client\"",
    "web:build": "bunx vite build --config web/vite.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/react-dom": "^19.2.3",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "openai": "^4.104.0",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^19.2.4",
    "wouter": "^3.9.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.7.0",
    "vite": "^8.0.3"
  },
  "keywords": [
    "cli",
    "social-media",
    "crosspost",
    "telegram",
    "twitter",
    "bluesky",
    "mastodon",
    "discord"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  }
}
