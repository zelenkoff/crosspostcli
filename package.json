{
  "name": "crosspost",
  "version": "0.1.0",
  "description": "Cross-platform content publishing from the terminal. Bring your own keys. No server. No subscription. Post everywhere.",
  "type": "module",
  "main": "src/cli.tsx",
  "bin": {
    "crosspost": "src/cli.tsx"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "build": "bun build src/cli.tsx --compile --outfile dist/crosspost",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "cli",
    "social-media",
    "crosspost",
    "telegram",
    "twitter",
    "bluesky",
    "mastodon",
    "discord"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  }
}
